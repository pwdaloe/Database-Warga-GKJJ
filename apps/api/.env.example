# Database
# Port 5435 (bukan 5432 default Postgres) — lihat docker-compose.yml, di-remap
# karena port 5432 dipakai instance PostgreSQL lokal lain, dan 5433/5434 dipakai project lain di mesin dev.
DATABASE_URL="postgresql://gkjj:gkjj_dev_password@localhost:5435/gkjj_db"

# Server
PORT=4000
NODE_ENV=development

# JWT — ganti dengan secret yang kuat di production!
JWT_SECRET="ganti-dengan-random-string-minimal-32-karakter"
JWT_EXPIRES_IN="7d"

# Enkripsi field sensitif (NIK) — UU PDP Pasal 4 ayat 2
# Gunakan: openssl rand -hex 32
ENCRYPTION_KEY="ganti-dengan-random-hex-64-karakter"

# CORS
CORS_ORIGIN="http://localhost:3000"

# File Upload (Cloudinary) — isi jika sudah punya akun
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email (reset password) — kosongkan SMTP_HOST untuk mode dev (email di-log ke console, tidak
# benar-benar terkirim). Isi dengan kredensial SMTP asli untuk production.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="GKJJ <no-reply@gkjjakarta.org>"

# URL frontend, dipakai untuk compose link reset password di email
APP_URL="http://localhost:3000"
