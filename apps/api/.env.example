# Database
# Port 5433 (bukan 5432 default Postgres) — lihat docker-compose.yml, di-remap
# karena port 5432 dipakai instance PostgreSQL lokal lain di mesin dev.
DATABASE_URL="postgresql://gkjj:gkjj_dev_password@localhost:5433/gkjj_db"

# Server
PORT=4000
NODE_ENV=development

# JWT — ganti dengan secret yang kuat di production!
JWT_SECRET="ganti-dengan-random-string-minimal-32-karakter"
JWT_EXPIRES_IN="7d"

# Enkripsi field sensitif (NIK) — UU PDP Pasal 4 ayat 2
# Gunakan: openssl rand -hex 32
ENCRYPTION_KEY="ganti-dengan-random-hex-64-karakter"

# CORS
CORS_ORIGIN="http://localhost:3000"

# File Upload (Cloudinary) — isi jika sudah punya akun
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
